NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# From https://searchadvisor.naver.com — site ownership verification meta tag
NAVER_SITE_VERIFICATION=
# Show view counts on public blog pages. Tracking keeps running either way —
# this only gates the UI. Flip to true once traffic is worth showing.
NEXT_PUBLIC_SHOW_VIEW_COUNT=false
# Google AdSense publisher ID (ca-pub-...) — loads adsbygoogle.js sitewide in production
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
